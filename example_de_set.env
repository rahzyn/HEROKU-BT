# ============================================================
# HEROKU-BT - Mfano wa Configuration
# Nakili faili hii na uipe jina "set.env" kisha jaza thamani
# ============================================================

# SESSION ID - Pata hii kutoka: https://heroku-pair.onrender.com
SESSION_ID="Zokou-MD-WHATSAPP-BOT;;;=>your_session_here"

# BOT SETTINGS
OWNER_NAME="Rahmany"
PREFIX="."
BOT_NAME="HEROKU-BT"
PUBLIC_MODE="non"           # "yes" = public mode, "non" = private mode

# OWNER INFO
NUMERO_OWNER="255693629079"  # Namba yako ya simu bila +

# AUTO STATUS
AUTO_READ_STATUS="non"       # "yes" au "non"
AUTO_DOWNLOAD_STATUS="oui"   # "yes" au "non"

# BOT MESSAGES
STARTING_BOT_MESSAGE="yes"
ANTI_DELETE1="yes"

# WARN COUNT
WARN_COUNT="3"

# BOT MENU IMAGE (optional)
IMAGE_MENU="https://files.catbox.moe/zotx9t.jpg"

# DATABASE - Weka URL ya PostgreSQL database yako
# Mfano: postgres://user:password@host:port/dbname
DATABASE_URL=""

# OPENAI (optional - kwa chatbot)
OPENAI_API_KEY=""

# HEROKU (optional - kwa auto-restart)
HEROKU_APP_NAME=""
HEROKU_APY_KEY=""
